PORT=5000
NODE_ENV=development

DB_SERVER=localhost
DB_PORT=1433
DB_NAME=flood_rescue_db
DB_USER=sa
DB_PASSWORD=12345
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

JWT_SECRET=flood-rescue-super-secret-key-change-in-production-2024
JWT_EXPIRES_IN=24h

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ============================================================
# CLOUDINARY - Lưu ảnh trên cloud (tuỳ chọn)
# Nếu không điền 3 key này → ảnh lưu local vào thư mục uploads/
# ============================================================
# Bước 1: Đăng ký tại https://cloudinary.com (miễn phí, không cần credit card)
# Bước 2: Vào Dashboard → copy Cloud Name, API Key, API Secret
# Bước 3: Paste vào đây
#
# Free tier: 25GB storage + 25GB bandwidth/tháng (đủ cho project)
# ============================================================
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Map APIs (hiện tại hệ thống dùng Leaflet + OpenStreetMap miễn phí, KHÔNG cần key)
# VIETMAP_API_KEY=your_vietmap_api_key_here
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================
# WEATHER API - OpenWeatherMap (MIỄN PHÍ)
# ============================================================
# Bước 1: Đăng ký tại https://home.openweathermap.org/users/sign_up
# Bước 2: Vào https://home.openweathermap.org/api_keys  
# Bước 3: Copy API key và paste vào đây
#
# Free tier: 1,000 calls/ngày (đủ cho project)
# Lưu ý: Key mới cần khoảng 2 giờ để kích hoạt
# ============================================================
OPENWEATHERMAP_API_KEY=86d11274ec5c68b6710c114168cd4f33

# Frontend URL (CORS)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
CITIZEN_RATE_LIMIT_MAX=10
# Giới hạn riêng cho đăng nhập (không đếm lần thành công)
LOGIN_RATE_LIMIT_MAX=50
